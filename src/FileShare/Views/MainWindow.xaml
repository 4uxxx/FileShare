<Window x:Class="FileShare.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FileShare.ViewModels"
        Title="FileShare" Height="780" Width="920" MinWidth="720" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Canvas}"
        FontFamily="{StaticResource Font.Sans}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <Grid MaxWidth="720" Margin="40,36,40,40" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== Header ===== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FileShare" Style="{StaticResource Text.Hero}" />
                    <Border Background="{StaticResource Brush.CanvasParchment}" CornerRadius="{StaticResource Radius.Pill}"
                            Padding="10,5" Margin="14,10,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource StatusDot}" Fill="{Binding IsSharing, Converter={StaticResource BoolToStatusBrush}}"
                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Caption}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock Text="自分のPC内のファイル・フォルダを、インターネット経由ですぐに共有できます。"
                           Style="{StaticResource Text.BodySecondary}" Margin="0,8,0,0" />
            </StackPanel>

            <!-- ===== Share card ===== -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="公開" Style="{StaticResource Text.H1}" />
                            <TextBlock Text="開始すると、下の一覧のファイル・フォルダがインターネットからダウンロードできるようになります。"
                                       Style="{StaticResource Text.BodySecondary}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource Button.Primary}"
                                Content="{Binding IsSharing, Converter={StaticResource BoolToShareLabel}}"
                                Command="{Binding ToggleShareCommand}" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0"
                                IsEnabled="{Binding IsSharing, Converter={StaticResource InverseBool}}">
                        <TextBlock Text="公開方法" Style="{StaticResource Text.LabelCaps}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <RadioButton Style="{StaticResource RadioPill}" GroupName="TunnelMode"
                                     IsChecked="{Binding IsCloudflareMode}" Content="毎回変わるURL" Margin="0,0,8,0" />
                        <RadioButton Style="{StaticResource RadioPill}" GroupName="TunnelMode"
                                     IsChecked="{Binding IsTailscaleMode}" Content="固定URL (Tailscale)" />
                    </StackPanel>

                    <!-- Public URL / QR / credentials, shown only while sharing -->
                    <Border Visibility="{Binding IsSharing, Converter={StaticResource BoolToVis}}"
                            BorderBrush="{StaticResource Brush.DividerSoft}" BorderThickness="0,1,0,0"
                            Margin="0,20,0,0" Padding="0,20,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="公開URL" Style="{StaticResource Text.LabelCaps}" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Style="{StaticResource Input}" Text="{Binding PublicUrl, Mode=OneWay}"
                                             IsReadOnly="True" />
                                    <Button Grid.Column="1" Style="{StaticResource Button.Secondary}" Content="コピー"
                                            Command="{Binding CopyUrlCommand}" Margin="8,0,0,0" />
                                </Grid>

                                <TextBlock Text="アクセス保護" Style="{StaticResource Text.LabelCaps}" Margin="0,20,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <ToggleButton Style="{StaticResource Switch}" IsChecked="{Binding AuthEnabled}" />
                                    <TextBlock Text="パスワードで保護する" Style="{StaticResource Text.Body}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Visibility="{Binding AuthEnabled, Converter={StaticResource BoolToVis}}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ユーザー名" Style="{StaticResource Text.Caption}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Style="{StaticResource Input}" Text="{Binding AuthUsername, UpdateSourceTrigger=LostFocus}" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="パスワード" Style="{StaticResource Text.Caption}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Style="{StaticResource Input}" Text="{Binding AuthPassword, UpdateSourceTrigger=LostFocus}" />
                                        <Button Grid.Column="2" Style="{StaticResource Button.Ghost}" Content="再生成"
                                                Command="{Binding RegeneratePasswordCommand}" Margin="6,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1" Background="{StaticResource Brush.CanvasParchment}" CornerRadius="{StaticResource Radius.Md}"
                                    Padding="12" VerticalAlignment="Top">
                                <Image Source="{Binding QrImage}" Width="132" Height="132" />
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== Shared items ===== -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="共有するファイル・フォルダ" Style="{StaticResource Text.H1}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource Button.Secondary}" Content="+ ファイルを追加" Command="{Binding AddFileCommand}" />
                            <Button Style="{StaticResource Button.Secondary}" Content="+ フォルダを追加" Command="{Binding AddFolderCommand}" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Quick-add chips for pinned paths -->
                    <ItemsControl ItemsSource="{Binding QuickChips}" Margin="0,14,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:QuickChipVm}">
                                <Button Command="{Binding DataContext.QuickAddCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,8,8"
                                        ToolTip="{Binding Path}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="chipBd" Style="{StaticResource Chip}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="+" Style="{StaticResource Text.Body}" FontWeight="Bold" Margin="0,0,6,0"
                                                                           Visibility="{Binding IsAdded, Converter={StaticResource BoolToVisInverse}}" />
                                                                <TextBlock Text="✓" Style="{StaticResource Text.Body}" Foreground="{StaticResource Brush.Primary}" FontWeight="Bold" Margin="0,0,6,0"
                                                                           Visibility="{Binding IsAdded, Converter={StaticResource BoolToVis}}" />
                                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                                                <Setter TargetName="chipBd" Property="Background" Value="{StaticResource Brush.PrimarySoft}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Exists}" Value="False">
                                                                <Setter TargetName="chipBd" Property="Opacity" Value="0.4" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Exists}" Value="False">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Shared item rows -->
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ItemRow}" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   Foreground="{StaticResource Brush.InkMuted48}"
                                                   Text="{Binding Kind, Converter={StaticResource ItemKindToGlyph}}"
                                                   VerticalAlignment="Center" Margin="0,0,14,0" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}" FontWeight="SemiBold" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Kind, Converter={StaticResource ItemKindToLabel}}" Style="{StaticResource Text.Caption}" />
                                                <TextBlock Text=" · " Style="{StaticResource Text.Caption}"
                                                           Visibility="{Binding Kind, Converter={StaticResource FileKindToVisibility}}" />
                                                <TextBlock Text="{Binding SizeBytes, Converter={StaticResource FileSize}}" Style="{StaticResource Text.Caption}"
                                                           Visibility="{Binding Kind, Converter={StaticResource FileKindToVisibility}}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2" Style="{StaticResource Button.Ghost}" Content="リンクをコピー"
                                                Command="{Binding DataContext.CopyItemLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" ToolTip="このアイテム専用のダウンロードリンクをコピー" Margin="0,0,4,0" />

                                        <Button Grid.Column="3" Style="{StaticResource Button.IconRound}" Content="✕"
                                                Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" ToolTip="共有から削除" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="まだファイル・フォルダが追加されていません。上のボタンから追加してください。"
                               Style="{StaticResource Text.BodySecondary}" Margin="0,8,0,0"
                               Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVis}}" />
                </StackPanel>
            </Border>

            <!-- ===== Access log ===== -->
            <Border Grid.Row="3" Style="{StaticResource CardParchment}">
                <StackPanel>
                    <TextBlock Text="アクセスログ" Style="{StaticResource Text.H2}" Margin="0,0,0,10" />
                    <ItemsControl ItemsSource="{Binding Logs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Time, StringFormat=HH:mm:ss}" Style="{StaticResource Text.Caption}" FontFamily="{StaticResource Font.Mono}" />
                                    <TextBlock Grid.Column="1" Text="{Binding RemoteAddress}" Style="{StaticResource Text.Caption}" FontFamily="{StaticResource Font.Mono}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Path}" Style="{StaticResource Text.Caption}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding StatusCode}" Style="{StaticResource Text.Caption}" FontFamily="{StaticResource Font.Mono}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="共有を開始すると、ここにアクセス状況が表示されます。" Style="{StaticResource Text.Caption}"
                               Visibility="{Binding Logs.Count, Converter={StaticResource ZeroToVis}}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
