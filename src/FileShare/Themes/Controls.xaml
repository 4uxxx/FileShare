<!--
    Controls.xaml
    Reusable control styles derived from the FileShare (Apple HIG-inspired) design tokens.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Typography ============ -->
    <Style x:Key="Text.Hero" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Hero}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Display}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
    </Style>

    <Style x:Key="Text.H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.H1}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
    </Style>

    <Style x:Key="Text.H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.H2}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Text.BodySecondary" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.InkMuted80}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.InkMuted48}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Text.LabelCaps" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.LabelCaps}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.InkMuted48}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <!-- ============ Card ============ -->
    <DropShadowEffect x:Key="Shadow.Card" Color="#000000" Opacity="0.06" BlurRadius="18" ShadowDepth="2" Direction="270" />

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Canvas}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Hairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Effect" Value="{StaticResource Shadow.Card}" />
    </Style>

    <Style x:Key="CardParchment" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Background" Value="{StaticResource Brush.CanvasParchment}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <!-- ============ Primary pill button ============ -->
    <Style x:Key="Button.Primary" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextInverse}" />
        <Setter Property="Background" Value="{StaticResource Brush.Primary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.PrimaryHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.PrimaryPress}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Secondary (outline) pill button ============ -->
    <Style x:Key="Button.Secondary" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
        <Setter Property="Background" Value="{StaticResource Brush.Canvas}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.PrimarySoft}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Ghost button ============ -->
    <Style x:Key="Button.Ghost" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Brush.InkMuted80}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.CanvasParchment}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Danger ghost button ============ -->
    <Style x:Key="Button.Danger" TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
    </Style>

    <!-- ============ Icon-only round button (remove "x") ============ -->
    <Style x:Key="Button.IconRound" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Brush.InkMuted48}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource Radius.Pill}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.DividerSoft}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Danger}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Text input (recessed well) ============ -->
    <Style x:Key="Input" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Ink}" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Primary}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfacePearl}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Hairline}" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Md}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Toggle switch ============ -->
    <Style x:Key="Switch" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" Background="{StaticResource Brush.Hairline}"
                            CornerRadius="12">
                        <Ellipse x:Name="knob" Width="18" Height="18" Margin="3"
                                 HorizontalAlignment="Left" Fill="White">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="3" ShadowDepth="1" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource Brush.Success}" />
                            <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Pill radio button (mode selector) ============ -->
    <Style x:Key="RadioPill" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Brush.InkMuted80}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Background="{StaticResource Brush.CanvasParchment}"
                            CornerRadius="{StaticResource Radius.Pill}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.PrimarySoft}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Chip (quick-add) ============ -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.CanvasParchment}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style x:Key="Chip.Active" TargetType="Border" BasedOn="{StaticResource Chip}">
        <Setter Property="Background" Value="{StaticResource Brush.PrimarySoft}" />
    </Style>

    <!-- ============ Status dot ============ -->
    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
    </Style>

    <!-- ============ List item hover row ============ -->
    <Style x:Key="ItemRow" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
        <Setter Property="Padding" Value="14,12" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.CanvasParchment}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============ ScrollViewer (thin, unobtrusive) ============ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb>
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="{StaticResource Brush.Hairline}" CornerRadius="4" Margin="2,0" />
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
