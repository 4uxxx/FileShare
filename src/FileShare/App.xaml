<Application x:Class="FileShare.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FileShare.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DesignTokens.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="BoolToVisInverse" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
            <conv:EmptyToCollapsedConverter x:Key="EmptyToCollapsed" />
            <conv:ZeroToVisibilityConverter x:Key="ZeroToVis" />
            <conv:FileSizeConverter x:Key="FileSize" />
            <conv:ItemKindToGlyphConverter x:Key="ItemKindToGlyph" />
            <conv:ItemKindToLabelConverter x:Key="ItemKindToLabel" />
            <conv:FileKindToVisibilityConverter x:Key="FileKindToVisibility" />
            <conv:BoolToShareLabelConverter x:Key="BoolToShareLabel" />
            <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
